APP_NAME=Watchtower
APP_ENV=local
# REQUIRED. Generate once with:  php artisan key:generate --show
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
# In Docker, compose overrides DB_HOST to the "db" service. 127.0.0.1 is for running
# artisan against the published Postgres port from your host.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=watchtower_hub
DB_USERNAME=watchtower
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Operator account auto-created on first boot; its mobile API token is printed
# once to the container logs (docker compose logs app). Token-only auth.
OPERATOR_EMAIL=admin@watchtower.local

# Proxmox VE — token must have the PVEAuditor role assigned
PROXMOX_BASE_URL=https://192.168.1.2:8006
PROXMOX_TOKEN_ID=watchtower@pam!hub
PROXMOX_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PROXMOX_VERIFY_TLS=false

# Proxmox Backup Server — token must have Datastore.Audit privilege
PBS_BASE_URL=https://192.168.1.3:8007
PBS_TOKEN_ID=watchtower@pbs!hub
PBS_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PBS_VERIFY_TLS=false

# ntfy push notifications — only Critical-tier alerts are pushed
NTFY_BASE_URL=http://192.168.1.30
NTFY_TOPIC=watchtower
# NTFY_TOKEN=                          # optional Bearer auth token

# Satellite health — staleness threshold for monitored-app snapshots
# APPS_STALE_AFTER_MINUTES=15          # minutes before a satellite snapshot is considered stale
